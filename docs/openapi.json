    "/api/threads/{thread_id}/events": {
      "get": {
        "tags": [
          "threads"
        ],
        "summary": "Stream Thread Events",
        "description": "Server-Sent Events stream. Events include reasoning, checkpoint, plan_ready, done, snapshot_required, and agent_error. The agent_error event payload contains state_version, code, and message.",
