  "components": {
    "schemas": {
      "ConfirmationAction": {
        "type": "string",
        "enum": [
          "approve",
          "edit",
          "refine",
          "reject"
        ],
        "title": "ConfirmationAction"
      },
      "ConfirmationRequest": {
        "properties": {
          "request_id": {
            "type": "string",
            "maxLength": 128,
            "minLength": 8,
            "title": "Request Id"
          },
          "action": {
            "$ref": "#/components/schemas/ConfirmationAction"
          },
          "task_tree": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/TaskTree"
              },
              {
                "type": "null"
              }
            ]
          },
          "feedback": {
            "anyOf": [
              {
                "type": "string",
                "maxLength": 2000
              },
              {
                "type": "null"
              }
            ],
            "title": "Feedback"
          },
          "reason": {
            "anyOf": [
              {
                "type": "string",
                "maxLength": 1000
              },
              {
                "type": "null"
              }
            ],
            "title": "Reason"
          }
        },
        "additionalProperties": false,
        "type": "object",
        "required": [
          "request_id",
          "action"
        ],
        "title": "ConfirmationRequest"
      },
      "ConfirmationResponse": {
        "properties": {
          "thread_id": {
            "type": "string",
            "title": "Thread Id"
          },
          "request_id": {
            "type": "string",
            "title": "Request Id"
          },
          "status": {
            "type": "string",
            "title": "Status"
          }
        },
        "type": "object",
        "required": [
          "thread_id",
          "request_id",
          "status"
        ],
        "title": "ConfirmationResponse"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "IntentCreateRequest": {
        "properties": {
          "intent_text": {
            "type": "string",
            "maxLength": 2000,
            "minLength": 1,
            "title": "Intent Text"
          },
          "preferred_provider": {
            "type": "string",
            "maxLength": 64,
            "title": "Preferred Provider",
            "default": "native"
          },
          "planner_provider": {
            "anyOf": [
              {
                "type": "string",
                "enum": [
                  "openai",
                  "deepseek",
                  "xiaomi"
                ]
              },
              {
                "type": "null"
              }
            ],
            "title": "Planner Provider"
          },
          "planner_model": {
            "anyOf": [
              {
                "type": "string",
                "maxLength": 128,
                "minLength": 1
              },
              {
                "type": "null"
              }
            ],
            "title": "Planner Model"
          }
        },
        "additionalProperties": false,
        "type": "object",
        "required": [
          "intent_text"
        ],
        "title": "IntentCreateRequest"
      },
      "IntentCreateResponse": {
        "properties": {
          "thread_id": {
            "type": "string",
            "title": "Thread Id"
          },
          "status": {
            "type": "string",
            "const": "running",
            "title": "Status"
          },
          "events_url": {
            "type": "string",
            "title": "Events Url"
          }
        },
        "type": "object",
        "required": [
          "thread_id",
          "status",
          "events_url"
        ],
        "title": "IntentCreateResponse"
      },
      "LoginRequest": {
        "properties": {
          "email": {
            "type": "string",
            "maxLength": 320,
            "minLength": 3,
            "title": "Email"
          },
          "password": {
            "type": "string",
            "maxLength": 128,
            "minLength": 8,
            "title": "Password"
          }
        },
        "additionalProperties": false,
        "type": "object",
        "required": [
          "email",
          "password"
        ],
        "title": "LoginRequest"
      },
      "RegisterRequest": {
        "properties": {
          "email": {
            "type": "string",
            "maxLength": 320,
            "minLength": 3,
            "title": "Email"
          },
          "password": {
            "type": "string",
            "maxLength": 128,
            "minLength": 8,
            "title": "Password"
          },
          "display_name": {
            "anyOf": [
              {
                "type": "string",
                "maxLength": 128
              },
              {
                "type": "null"
              }
            ],
            "title": "Display Name"
          }
        },
        "additionalProperties": false,
        "type": "object",
        "required": [
          "email",
          "password"
        ],
        "title": "RegisterRequest"
      },
      "TaskCreateRequest": {
        "properties": {
          "title": {
            "type": "string",
            "maxLength": 160,
            "minLength": 1,
            "title": "Title"
          },
          "description": {
            "anyOf": [
              {
                "type": "string",
                "maxLength": 1000
              },
              {
                "type": "null"
              }
            ],
            "title": "Description"
          },
          "view_bucket": {
            "type": "string",
            "enum": [
              "planned",
              "my_day",
              "backlog"
            ],
            "title": "View Bucket",
            "default": "planned"
          },
          "is_in_my_day": {
            "type": "boolean",
            "title": "Is In My Day",
            "default": false
          },
          "parent_task_id": {
            "anyOf": [
              {
                "type": "string",
                "format": "uuid"
              },
              {
                "type": "null"
              }
            ],
            "title": "Parent Task Id"
          },
          "thread_id": {
            "anyOf": [
              {
                "type": "string",
                "maxLength": 128,
                "minLength": 1
              },
              {
                "type": "null"
              }
            ],
            "title": "Thread Id"
          }
        },
        "additionalProperties": false,
        "type": "object",
        "required": [
          "title"
        ],
        "title": "TaskCreateRequest"
      },
      "TaskNode": {
        "properties": {
          "client_node_id": {
            "type": "string",
            "minLength": 1,
            "title": "Client Node Id"
          },
          "title": {
            "type": "string",
            "maxLength": 160,
            "minLength": 1,
            "title": "Title"
          },
          "description": {
            "anyOf": [
              {
                "type": "string",
                "maxLength": 1000
              },
              {
                "type": "null"
              }
            ],
            "title": "Description"
          },
          "verb": {
            "type": "string",
            "minLength": 1,
            "title": "Verb"
          },
          "estimated_minutes": {
            "type": "integer",
            "maximum": 43200.0,
            "minimum": 0.0,
            "title": "Estimated Minutes"
          },
          "node_type": {
            "type": "string",
            "enum": [
              "group",
              "action"
            ],
            "title": "Node Type"
          },
          "depends_on": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Depends On"
          },
          "children": {
            "items": {
              "$ref": "#/components/schemas/TaskNode"
            },
            "type": "array",
            "maxItems": 20,
            "title": "Children"
          },
          "done_criteria": {
            "anyOf": [
              {
                "type": "string",
                "maxLength": 1000
              },
              {
                "type": "null"
              }
            ],
            "title": "Done Criteria"
          },
          "start_hint": {
            "anyOf": [
              {
                "type": "string",
                "maxLength": 1000
              },
              {
                "type": "null"
              }
            ],
            "title": "Start Hint"
          },
          "fallback_action": {
            "anyOf": [
              {
                "type": "string",
                "maxLength": 1000
              },
              {
                "type": "null"
              }
            ],
            "title": "Fallback Action"
