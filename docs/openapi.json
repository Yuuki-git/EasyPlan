        "parameters": [
          {
            "name": "thread_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "minLength": 1,
              "title": "Thread Id"
            }
          },
          {
            "name": "last_event_id",
            "in": "query",
