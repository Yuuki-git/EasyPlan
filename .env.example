# --- EasyPlan Deployment Config ---

# PostgreSQL / pgvector
POSTGRES_DB=easyplan
POSTGRES_USER=easyplan
POSTGRES_PASSWORD=change_me
DATABASE_URL=postgresql+psycopg://easyplan:change_me@db:5432/easyplan

# HTTP / CORS
EASYPLAN_CORS_ORIGINS=https://app.easyplan.example,http://localhost:8080

# JWT Security
# Generate with: openssl rand -hex 32
EASYPLAN_JWT_SECRET=change_me_with_64_hex_chars
JWT_SECRET_KEY=change_me_with_64_hex_chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# LLM Provider
EASYPLAN_LLM_PROVIDER=openai
OPENAI_API_KEY=your_openai_api_key_here
EASYPLAN_OPENAI_MODEL=gpt-4o-2024-08-06
DEEPSEEK_API_KEY=your_deepseek_api_key_here
EASYPLAN_DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com
XIAOMI_API_KEY=your_xiaomi_mimo_api_key_here
EASYPLAN_XIAOMI_MIMO_MODEL=mimo-v2-flash
XIAOMI_MIMO_BASE_URL=https://api.xiaomimimo.com/v1

# Todoist OAuth
TODOIST_CLIENT_ID=your_todoist_client_id
TODOIST_CLIENT_SECRET=your_todoist_client_secret

# Frontend build/runtime
VITE_API_BASE_URL=http://localhost:8000
