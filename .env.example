# --- EasyPlan Backend Config ---

# LLM Provider (OpenAI / Claude)
OPENAI_API_KEY=your_openai_api_key_here
# ANTHROPIC_API_KEY=your_claude_api_key_here

# Database
# For local dev: postgresql+asyncpg://user:password@localhost:5432/easyplan
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/easyplan

# JWT Security
# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=your_super_secret_jwt_key_here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Todoist OAuth
TODOIST_CLIENT_ID=your_todoist_client_id
TODOIST_CLIENT_SECRET=your_todoist_client_secret

# --- EasyPlan Frontend Config ---
VITE_API_BASE_URL=http://localhost:8000
