# --- EasyPlan Deployment Config ---

# ==========================================
# 1. PostgreSQL Database Configuration
# ==========================================
POSTGRES_DB=easyplan
# [ACTION REQUIRED]: Change the default user and password for production.
POSTGRES_USER=easyplan_admin
POSTGRES_PASSWORD=your_secure_db_password_here
# [ACTION REQUIRED]: Ensure the credentials match POSTGRES_USER and POSTGRES_PASSWORD above.
# The format is postgresql+psycopg://[user]:[password]@db:5432/[db_name]
DATABASE_URL=postgresql+psycopg://easyplan_admin:your_secure_db_password_here@db:5432/easyplan

# ==========================================
# 2. HTTP / CORS Security
# ==========================================
# [ACTION REQUIRED]: Replace with your actual frontend domain(s) in production (e.g., https://app.easyplan.com)
# Separate multiple URLs with a comma. Do NOT add a trailing slash.
EASYPLAN_CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ==========================================
# 3. JWT Security (Authentication)
# ==========================================
# [ACTION REQUIRED]: Generate a secure random string (e.g., run `openssl rand -hex 32` in terminal)
# IMPORTANT: Both EASYPLAN_JWT_SECRET and JWT_SECRET_KEY MUST be identical.
EASYPLAN_JWT_SECRET=your_generated_64_character_hex_string_here
JWT_SECRET_KEY=your_generated_64_character_hex_string_here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ==========================================
# 4. LLM Provider (AI Planning)
# ==========================================
# Choose your preferred provider (openai, deepseek, xiaomi)
EASYPLAN_LLM_PROVIDER=openai

# OpenAI Config
# [ACTION REQUIRED if using OpenAI]: Enter your API key.
OPENAI_API_KEY=your_openai_api_key_here
EASYPLAN_OPENAI_MODEL=gpt-4o-2024-08-06

# DeepSeek Config
# [ACTION REQUIRED if using DeepSeek]: Enter your API key.
DEEPSEEK_API_KEY=your_deepseek_api_key_here
EASYPLAN_DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Xiaomi MiMo Config
# [ACTION REQUIRED if using Xiaomi]: Enter your API key.
XIAOMI_API_KEY=your_xiaomi_mimo_api_key_here
EASYPLAN_XIAOMI_MIMO_MODEL=mimo-v2-flash
XIAOMI_MIMO_BASE_URL=https://api.xiaomimimo.com/v1

# ==========================================
# 5. OAuth External Integrations
# ==========================================
# [ACTION REQUIRED]: Obtain these from the Todoist App Console (https://developer.todoist.com/appconsole)
TODOIST_CLIENT_ID=your_todoist_client_id_here
TODOIST_CLIENT_SECRET=your_todoist_client_secret_here

# [ACTION REQUIRED if using Microsoft To Do]: Obtain these from Microsoft Entra app registrations.
MICROSOFT_CLIENT_ID=your_microsoft_client_id_here
MICROSOFT_CLIENT_SECRET=your_microsoft_client_secret_here

# ==========================================
# 6. Frontend Build/Runtime
# ==========================================
# [ACTION REQUIRED for Production]: Change to your backend's public URL (e.g., https://api.easyplan.com)
VITE_API_BASE_URL=http://localhost:8000
